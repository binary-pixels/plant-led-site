# Resend API Key - Get from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email to receive customer inquiries
INQUIRY_EMAIL=your-email@example.com

# Google Analytics Measurement ID (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Tawk.to Live Chat - Get from https://tawk.to (create a property)
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=your_property_id
NEXT_PUBLIC_TAWKTO_WIDGET_ID=your_widget_id

# DeepL API Key - Get from https://deepl.com/pro-api (required for chat translation)
# Free tier: 500k characters/month
DEEPL_API_KEY=your_deepl_api_key

# Supabase - Get from your Supabase project dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin dashboard password (required for /admin/login)
ADMIN_PASSWORD=your_admin_password
